{
  "name": "openclaw-panel",
  "version": "1.0.0",
  "private": true,
  "description": "OpenClaw cloud server management panel",
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "build": "pnpm --filter frontend build",
    "start": "pnpm --filter backend start",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf node_modules dist"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
